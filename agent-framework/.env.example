# Kite Chain
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_CHAIN_ID=2368

# Agent wallets — each agent needs its own private key + funded USDC
AGENT_A_PRIVATE_KEY=0x_AGENT_A_KEY
AGENT_B_PRIVATE_KEY=0x_AGENT_B_KEY
AGENT_C_PRIVATE_KEY=0x_AGENT_C_KEY

# Contract addresses (copy from deployments.json after running deploy)
PREDICTION_MARKET_ADDRESS=
AGENT_VAULT_ADDRESS=
SKILL_LIBRARY_ADDRESS=
USDC_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# APIs
NEWSAPI_KEY=        # free tier: https://newsapi.org — leave blank to skip sentiment
COINGECKO_API_KEY=  # optional, free API works without key

# Betting config
MIN_CONFIDENCE_TO_BET=40     # don't bet if confidence < 40%
BASE_STAKE_USDC=100          # base stake in USDC (6 decimals handled internally)
MAX_STAKE_USDC=500           # cap per agent per prediction
