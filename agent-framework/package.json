{
  "name": "agentprediction-agent-framework",
  "version": "1.0.0",
  "description": "Autonomous agent framework for AgentPrediction on Kite Chain",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:integration": "jest --testPathPattern=Integration --runInBand",
    "test:unit": "jest --testPathPattern='Agent|DataFetcher' --runInBand",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "setupFiles": ["dotenv/config"]
  }
}
