# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456:ABC-your-bot-token
BOT_WEBHOOK_URL=https://your-bot.vercel.app/api/telegram
# Leave blank to use polling mode (local dev with ts-node)

# ── Kite Chain ────────────────────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_CHAIN_ID=2368

# ── Contract Addresses (from deployments.json after deploy) ───────────────────
PREDICTION_MARKET_ADDRESS=
AGENT_VAULT_ADDRESS=
USDC_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# ── Deployer wallet (creates markets + resolves) ──────────────────────────────
KITE_PRIVATE_KEY=0x_your_deployer_key

# ── Agent wallets ─────────────────────────────────────────────────────────────
AGENT_A_PRIVATE_KEY=0x_agent_a_key
AGENT_B_PRIVATE_KEY=0x_agent_b_key
AGENT_C_PRIVATE_KEY=0x_agent_c_key

# ── Demo user wallet (shared for demo bets) ───────────────────────────────────
DEMO_USER_PRIVATE_KEY=0x_demo_user_key

# ── Agent config ──────────────────────────────────────────────────────────────
MIN_CONFIDENCE_TO_BET=40
BASE_STAKE_USDC=100
MAX_STAKE_USDC=500

# ── APIs ──────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=
COINGECKO_API_KEY=

# ── Goldsky ───────────────────────────────────────────────────────────────────
GOLDSKY_SUBGRAPH_URL=
